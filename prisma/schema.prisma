generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  email        String    @unique
  passwordHash String
  firstName    String?
  lastName     String?
  role         UserRole  @default(USER)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime? @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([email])
}

enum UserRole {
  ADMIN
  USER
}

model Company {
  id               String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  name             String
  domain           String?   @unique
  industry         String?
  size             String?
  location         String?
  city             String?
  state            String?
  country          String?
  linkedinUrl      String?
  website          String?
  revenue          String?
  apolloId         String?   @unique
  enrichmentData   Json?
  createdAt        DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  dataSources      String[]  @default([])
  dataQuality      Int?      @default(0)
  apifyId          String?   @unique
  hunterEnrichedAt DateTime?
  contacts         Contact[]

  @@index([domain])
  @@index([name])
  @@index([apifyId])
  @@index([dataQuality])
}

model Contact {
  id                      String                @id @default(dbgenerated("(gen_random_uuid())::text"))
  email                   String?               @unique
  firstName               String?
  lastName                String?
  fullName                String?
  phone                   String?
  phoneFormatted          String?
  title                   String?
  linkedinUrl             String?
  linkedinId              String?
  timezone                String?
  city                    String?
  state                   String?
  country                 String?
  companyId               String?
  status                  ContactStatus         @default(NEW)
  emailValidationStatus   EmailValidationStatus @default(PENDING)
  emailValidationAttempts Int                   @default(0)
  phoneValidationStatus   PhoneValidationStatus @default(PENDING)
  emailValidatedAt        DateTime?             @db.Timestamptz(6)
  phoneValidatedAt        DateTime?             @db.Timestamptz(6)
  source                  String?
  sourceId                String?
  apolloId                String?               @unique
  hasReplied              Boolean               @default(false)
  repliedAt               DateTime?             @db.Timestamptz(6)
  repliedChannel          OutreachChannel?
  tags                    String[]              @default([])
  customFields            Json?
  enrichmentData          Json?
  createdAt               DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt               DateTime              @default(now()) @updatedAt @db.Timestamptz(6)
  lastContactedAt         DateTime?             @db.Timestamptz(6)
  ghlContactId            String?               @unique
  ghlConversationId       String?
  dataSources             String[]              @default([])
  dataQuality             Int?                  @default(0)
  apifyId                 String?               @unique
  hunterEnrichedAt        DateTime?
  hunterScore             Int?
  shovelsContractorId     String?
  shovelsEmployeeId       String?
  permitType              String?
  permitCity              String?
  licenseNumber           String?
  permitSearchId          String?

  // Promoted permit fields (for Instantly personalization)
  permitDate         String?
  permitDateFriendly String?
  permitMonthsAgo    Int?
  permitDescription  String?
  permitStatus       String?
  permitNumber       String?
  permitJobValue     Float?
  permitFees         Float?
  permitJurisdiction String?

  // Promoted contractor fields
  avgJobValue          Float?
  totalJobValue        Float?
  permitCount          Int?
  revenue              String?
  employeeCount        String?
  website              String?
  rating               Float?
  reviewCount          Int?
  seniorityLevel       String?
  department           String?
  tagTally             Json?
  clayEnrichmentStatus ClayStatus           @default(PENDING)
  clayEnrichedAt       DateTime?            @db.Timestamptz(6)
  googlePlaceId        String?              @unique
  activityLogs         ActivityLog[]
  campaignEnrollments  CampaignEnrollment[]
  company              Company?             @relation(fields: [companyId], references: [id])
  linkedInActions      LinkedInAction[]
  outreachSteps        OutreachStep[]
  replies              Reply[]
  sequenceEnrollments  SequenceEnrollment[]
  connections          Connection[]
  labels               ContactLabel[]

  @@index([email])
  @@index([status])
  @@index([companyId])
  @@index([hasReplied])
  @@index([createdAt])
  @@index([apifyId])
  @@index([dataQuality])
  @@index([ghlContactId])
}

model Campaign {
  id                  String                @id @default(uuid())
  name                String
  channel             OutreachChannel
  instantlyCampaignId String?
  phantomBusterId     String?
  googleSheetUrl      String?
  status              CampaignStatus        @default(DRAFT)
  description         String?
  settings            Json?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  linkedinEnabled     Boolean               @default(true)
  enrollments         CampaignEnrollment[]
  routingRules        CampaignRoutingRule[]

  @@index([status])
  @@index([channel])
  @@index([instantlyCampaignId])
  @@index([createdAt])
}

model CampaignRoutingRule {
  id                 String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  name               String
  description        String?
  priority           Int      @default(0)
  isActive           Boolean  @default(true)
  matchMode          String   @default("ALL")
  sourceFilter       String[] @default([])
  industryFilter     String[] @default([])
  stateFilter        String[] @default([])
  countryFilter      String[] @default([])
  tagsFilter         String[] @default([])
  employeesMinFilter Int?
  employeesMaxFilter Int?
  campaignId         String
  createdAt          DateTime @default(now()) @db.Timestamp(6)
  updatedAt          DateTime @default(now()) @updatedAt @db.Timestamp(6)
  campaign           Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([isActive, priority(sort: Desc)])
  @@index([campaignId])
}

model CampaignEnrollment {
  id            String           @id @default(uuid())
  campaignId    String
  contactId     String
  status        EnrollmentStatus @default(ENROLLED)
  enrolledAt    DateTime         @default(now())
  stoppedAt     DateTime?
  stoppedReason String?
  externalId    String?
  metadata      Json?
  campaign      Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact       Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
  @@index([campaignId])
  @@index([contactId])
  @@index([status])
  @@index([enrolledAt])
}

model Sequence {
  id                String               @id @default(dbgenerated("(gen_random_uuid())::text"))
  name              String
  description       String?
  status            SequenceStatus       @default(DRAFT)
  channels          OutreachChannel[]    @default([])
  settings          Json?
  businessHoursOnly Boolean              @default(true)
  respectTimezone   Boolean              @default(true)
  maxContactsPerDay Int?
  totalEnrolled     Int                  @default(0)
  totalCompleted    Int                  @default(0)
  totalReplied      Int                  @default(0)
  createdAt         DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime             @default(now()) @updatedAt @db.Timestamptz(6)
  excludeWeekends   Boolean              @default(true)
  enrollments       SequenceEnrollment[]
  steps             SequenceStep[]

  @@index([status])
}

model SequenceStep {
  id                 String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  sequenceId         String
  order              Int
  channel            OutreachChannel
  delayDays          Int                 @default(0)
  delayHours         Int                 @default(0)
  delayMinutes       Int                 @default(0)
  subject            String?
  body               String
  templateId         String?
  linkedinActionType LinkedInActionType?
  randomDelayMin     Int                 @default(0)
  randomDelayMax     Int                 @default(30)
  variants           Json?
  totalSent          Int                 @default(0)
  totalDelivered     Int                 @default(0)
  totalOpened        Int                 @default(0)
  totalClicked       Int                 @default(0)
  totalReplied       Int                 @default(0)
  createdAt          DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime            @default(now()) @updatedAt @db.Timestamptz(6)
  outreachSteps      OutreachStep[]
  sequence           Sequence            @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, order])
  @@index([sequenceId])
}

model SequenceEnrollment {
  id               String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  contactId        String
  sequenceId       String
  currentStepOrder Int           @default(0)
  status           ContactStatus @default(IN_SEQUENCE)
  isPaused         Boolean       @default(false)
  pausedAt         DateTime?     @db.Timestamptz(6)
  pauseReason      String?
  enrolledAt       DateTime      @default(now()) @db.Timestamptz(6)
  completedAt      DateTime?     @db.Timestamptz(6)
  lastStepAt       DateTime?     @db.Timestamptz(6)
  nextStepAt       DateTime?     @db.Timestamptz(6)
  contact          Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  sequence         Sequence      @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([contactId, sequenceId])
  @@index([sequenceId])
  @@index([status])
  @@index([nextStepAt])
}

model OutreachStep {
  id             String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  contactId      String
  sequenceStepId String?
  channel        OutreachChannel
  status         OutreachStepStatus @default(PENDING)
  scheduledAt    DateTime?          @db.Timestamptz(6)
  sentAt         DateTime?          @db.Timestamptz(6)
  deliveredAt    DateTime?          @db.Timestamptz(6)
  openedAt       DateTime?          @db.Timestamptz(6)
  clickedAt      DateTime?          @db.Timestamptz(6)
  repliedAt      DateTime?          @db.Timestamptz(6)
  failedAt       DateTime?          @db.Timestamptz(6)
  subject        String?
  body           String?
  externalId     String?
  messageId      String?
  errorMessage   String?
  errorCode      String?
  retryCount     Int                @default(0)
  maxRetries     Int                @default(3)
  metadata       Json?
  createdAt      DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime           @default(now()) @updatedAt @db.Timestamptz(6)
  contact        Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  sequenceStep   SequenceStep?      @relation(fields: [sequenceStepId], references: [id])

  @@index([contactId])
  @@index([status])
  @@index([scheduledAt])
  @@index([channel])
}

model LinkedInAction {
  id               String                   @id @default(dbgenerated("(gen_random_uuid())::text"))
  contactId        String
  actionType       LinkedInActionType
  status           OutreachStepStatus       @default(PENDING)
  connectionStatus LinkedInConnectionStatus @default(NOT_CONNECTED)
  scheduledAt      DateTime?                @db.Timestamptz(6)
  executedAt       DateTime?                @db.Timestamptz(6)
  message          String?
  phantomId        String?
  phantomOutput    Json?
  errorMessage     String?
  retryCount       Int                      @default(0)
  createdAt        DateTime                 @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime                 @default(now()) @updatedAt @db.Timestamptz(6)
  contact          Contact                  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([status])
  @@index([scheduledAt])
}

enum ReplyClassification {
  BOOK_CALL
  MORE_INFO
  NOT_INTERESTED
  OBJECTION
  UNKNOWN
}

model Reply {
  id             String               @id @default(dbgenerated("(gen_random_uuid())::text"))
  contactId      String
  channel        OutreachChannel
  content        String?
  subject        String?
  externalId     String?
  messageId      String?
  inReplyTo      String?
  fromAddress    String?
  receivedAt     DateTime             @db.Timestamptz(6)
  rawPayload     Json?
  isProcessed    Boolean              @default(false)
  processedAt    DateTime?            @db.Timestamptz(6)
  createdAt      DateTime             @default(now()) @db.Timestamptz(6)
  threadId       String?
  classification ReplyClassification?
  classifiedAt   DateTime?            @db.Timestamptz(6)
  contact        Contact              @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([channel])
  @@index([receivedAt])
  @@index([isProcessed])
  @@index([classification])
}

model ActivityLog {
  id          String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  contactId   String?
  action      String
  channel     OutreachChannel?
  description String?
  metadata    Json?
  actorType   String           @default("system")
  actorId     String?
  createdAt   DateTime         @default(now()) @db.Timestamptz(6)
  contact     Contact?         @relation(fields: [contactId], references: [id])

  @@index([contactId])
  @@index([action])
  @@index([createdAt])
}

model SystemConfig {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  key         String   @unique
  value       Json
  description String?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz(6)
}

model RateLimitLog {
  id          String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  channel     OutreachChannel
  action      String
  count       Int             @default(1)
  windowStart DateTime        @db.Timestamptz(6)
  windowEnd   DateTime        @db.Timestamptz(6)
  createdAt   DateTime        @default(now()) @db.Timestamptz(6)

  @@index([channel, windowStart])
}

model WebhookLog {
  id           String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  source       String
  eventType    String
  payload      Json
  processed    Boolean   @default(false)
  processedAt  DateTime? @db.Timestamptz(6)
  errorMessage String?
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)

  @@index([source])
  @@index([processed])
  @@index([createdAt])
}

model ImportJob {
  id               String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  type             ImportJobType
  status           ImportJobStatus @default(PENDING)
  totalRecords     Int             @default(0)
  processedRecords Int             @default(0)
  successCount     Int             @default(0)
  duplicateCount   Int             @default(0)
  invalidCount     Int             @default(0)
  errorCount       Int             @default(0)
  errors           Json?
  metadata         Json?
  createdAt        DateTime        @default(now()) @db.Timestamptz(6)
  startedAt        DateTime?       @db.Timestamptz(6)
  completedAt      DateTime?       @db.Timestamptz(6)
  updatedAt        DateTime        @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([status])
  @@index([createdAt])
}

model Settings {
  id                      String   @id @default(uuid())
  linkedinGloballyEnabled Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @default(now()) @updatedAt
  defaultEmailCampaignId  String?
  defaultSmsCampaignId    String?

  // Apify (Google Maps) Scraper - New array-based fields
  apifySearchTerms        String[] @default([])
  apifyLocations          String[] @default([])
  apifyIndustries         String[] @default([])
  apifyMaxResults         Int?
  apifyMinRating          Float?   @default(0)
  apifyRequirePhone       Boolean  @default(true)
  apifyRequireWebsite     Boolean  @default(false)
  apifySkipClosed         Boolean  @default(true)
  apifyLanguage           String?
  apifySearchMatching     String?
  apifyScrapePlaceDetails Boolean  @default(false)
  apifyScrapeContacts     Boolean  @default(false)
  apifyScrapeReviews      Boolean  @default(false)
  apifyMaxReviews         Int?     @default(0)
  apifyScrapeSocialMedia  Json?
  apifyMinReviewCount     Int?     @default(0)

  // Apollo Scraper
  apolloIndustry                String?
  apolloPersonTitles            String[] @default([])
  apolloLocations               String[] @default([])
  apolloExcludeLocations        String[] @default([])
  apolloEmployeesMin            Int?
  apolloEmployeesMax            Int?
  apolloRevenueMin              Int?
  apolloRevenueMax              Int?
  apolloEnrichLimit             Int      @default(100)
  apolloEnrichPhones            Boolean  @default(true)
  apolloSearchKeywords          String?
  apolloPersonLocations         String[] @default([])
  apolloPersonSeniorities       String[] @default([])
  apolloOrganizationKeywordTags String[] @default([])
  apolloNegativeKeywordTags     String[] @default([])
  apolloTechnologies            String[] @default([])
  apolloIndustryTagIds          String[] @default([])
  apolloEmployeeGrowthRate      String?
  apolloFundingStage            String?
  apolloPage                    Int      @default(1)
  apolloPerPage                 Int      @default(100)

  // Pipeline Controls
  pipelineEnabled      Boolean   @default(true)
  emailOutreachEnabled Boolean   @default(true)
  smsOutreachEnabled   Boolean   @default(true)
  maintenanceMode      Boolean   @default(false)
  maintenanceMessage   String?
  schedulerEnabled     Boolean   @default(true)
  scrapeJobEnabled     Boolean   @default(true)
  apolloJobEnabled     Boolean   @default(true)
  enrichJobEnabled     Boolean   @default(true)
  mergeJobEnabled      Boolean   @default(true)
  validateJobEnabled   Boolean   @default(true)
  enrollJobEnabled     Boolean   @default(true)
  lastEmergencyStopAt  DateTime? @db.Timestamp(6)
  lastEmergencyStopBy  String?

  // Schedule Management
  scheduleTemplate String? @default("balanced")
  scrapeJobCron    String? @default("0 6 * * *")
  apolloJobCron    String? @default("30 6 * * *")
  enrichJobCron    String? @default("0 8 * * *")
  mergeJobCron     String? @default("0 9 * * *")
  validateJobCron  String? @default("0 10 * * *")
  enrollJobCron    String? @default("0 11 * * *")

  // Campaign Routing
  routingFallbackBehavior String? @default("default_campaign")

  // Shovels Permit Scraper
  shovelsJobEnabled      Boolean  @default(true)
  shovelsJobCron         String?  @default("0 7 * * *")
  shovelsPermitTypes     String[] @default([])
  shovelsGeoIds          String[] @default([])
  shovelsLocations       String[] @default([])
  shovelsDateRangeDays   Int?     @default(365)
  shovelsMaxResults      Int?     @default(100)
  shovelsEnableEmployees Boolean  @default(true)

  // Employee Filtering
  shovelsEmployeeSeniorityFilter  String[] @default(["Senior", "Executive"])
  shovelsEmployeeDepartmentFilter String[] @default(["Operations", "Management", "Administration"])
  shovelsEmployeeTitleInclude     String[] @default(["Owner", "President", "CEO", "Founder", "Director", "VP", "Vice President"])
  shovelsEmployeeTitleExclude     String[] @default(["Technician", "Installer", "Helper", "Laborer", "Apprentice"])

  // Homeowner Scraper
  homeownerJobEnabled         Boolean  @default(false)
  homeownerJobCron            String?  @default("0 9 * * *")
  homeownerGeoIds             String[] @default([])
  homeownerLocations          String[] @default([])
  homeownerMaxResults         Int?     @default(100)
  homeownerRealieEnrich       Boolean  @default(true)
  homeownerUseShovelsGeoIds   Boolean  @default(true)
  homeownerFetchPermitDetails Boolean  @default(true)
  homeownerRealieFallback     Boolean  @default(true)

  // Connection Resolver
  connectionJobEnabled Boolean @default(false)
  connectionJobCron    String? @default("30 9 * * *")
  connectionBatchSize  Int?    @default(50)

  // Permit Routing
  permitRouteMode               String? @default("email")
  permitEmailCampaignId         String?
  permitGhlWorkflowId           String?
  permitGhlEmailReplyWorkflowId String?
  permitGhlSmsReplyWorkflowId   String?
  permitSmsFallbackEnabled      Boolean @default(true)
  permitAutoRouteEnabled        Boolean @default(false)

  // SMS Fallback Delay
  smsFallbackDelayDays Int? @default(5)

  // GHL Pipeline Settings
  ghlPipelineId     String?
  ghlDefaultStageId String?
}

model Homeowner {
  id                String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  shovelsResidentId String   @unique
  firstName         String?
  lastName          String?
  fullName          String?
  email             String?
  phone             String?
  street            String?
  city              String?
  state             String?
  zipCode           String?
  county            String?
  gender            String?
  ageRange          String?
  isMarried         Boolean?
  hasChildren       Boolean?
  incomeRange       String?
  netWorth          String?
  education         String?
  homeownerFlag     String?

  propertyAddress String?
  propertyValue   String?
  propertyType    String?
  yearBuilt       String?
  lotSize         String?
  livingArea      String?
  bedrooms        Int?
  bathrooms       Int?

  permitIds  String[] @default([])
  permitType String?
  permitCity String?
  geoId      String?

  // Permit detail fields (fetched from Shovels permits)
  permitDate         String?
  permitDateFriendly String?
  permitMonthsAgo    Int?
  permitDescription  String?
  permitJobValue     Float?
  permitStatus       String?
  permitNumber       String?
  permitFees         Float?
  permitJurisdiction String?

  // Shovels contact enrichment
  shovelsContactEnriched   Boolean   @default(false)
  shovelsContactEnrichedAt DateTime? @db.Timestamptz(6)

  // Realie enrichment
  realieEnriched    Boolean   @default(false)
  realieEnrichedAt  DateTime? @db.Timestamptz(6)
  assessedValue     Float?
  taxAmount         Float?
  avmValue          Float?
  avmMin            Float?
  avmMax            Float?
  ownerName         String?
  totalBedrooms     Int?
  totalBathrooms    Float?
  buildingArea      Float?
  stories           Int?
  hasPool           Boolean?
  hasGarage         Boolean?
  garageCount       Int?
  fireplaceCount    Int?
  constructionType  String?
  roofType          String?
  foundationType    String?
  lienCount         Int?
  lienBalance       Float?
  equityEstimate    Float?
  loanToValue       Float?
  lastTransferDate  String?
  lastTransferPrice Float?
  latitude          Float?
  longitude         Float?
  realieRawData     Json?

  status         String   @default("NEW")
  source         String   @default("shovels")
  dataSources    String[] @default(["SHOVELS"])
  tags           String[] @default([])
  enrichmentData Json?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  connections Connection[]

  @@index([email])
  @@index([city, state])
  @@index([geoId])
  @@index([status])
  @@index([realieEnriched])
  @@index([shovelsContactEnriched])
  @@index([createdAt])
}

model Connection {
  id                String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  contactId         String
  homeownerId       String
  permitId          String
  permitType        String?
  permitDate        String?
  permitJobValue    Float?
  permitDescription String?
  source            String   @default("shovels")
  createdAt         DateTime @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  homeowner Homeowner @relation(fields: [homeownerId], references: [id], onDelete: Cascade)

  @@unique([contactId, homeownerId, permitId])
  @@index([contactId])
  @@index([homeownerId])
  @@index([permitId])
  @@index([createdAt])
}

model ContactLabel {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  contactId String
  name      String // e.g. "Hot", "Warm", "Cold", "Customer", "DNC"
  color     String? // hex or tailwind color name
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, name])
  @@index([contactId])
}

model MessageTemplate {
  id          String          @id @default(uuid())
  name        String
  channel     TemplateChannel @default(SMS)
  subject     String?
  body        String
  description String?
  isDefault   Boolean         @default(false)
  isActive    Boolean         @default(true)
  usageCount  Int             @default(0)
  lastUsedAt  DateTime?
  variables   String[]        @default([])
  tags        String[]        @default([])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @default(now()) @updatedAt

  @@index([channel])
  @@index([isDefault])
  @@index([isActive])
}

model MergedContact {
  id                 String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  winnerContactId    String
  loserContactId     String
  loserEmail         String
  mergeStrategy      String
  winnerScore        Int?
  loserScore         Int?
  fieldsMerged       Json?
  outreachStepsMoved Int       @default(0)
  repliesMoved       Int       @default(0)
  activityLogsMoved  Int       @default(0)
  enrollmentsDeleted Int       @default(0)
  loserSnapshot      Json
  mergedBy           String?
  mergedAt           DateTime  @default(now())
  canRollback        Boolean   @default(true)
  rolledBackAt       DateTime?

  @@index([winnerContactId])
  @@index([loserContactId])
  @@index([loserEmail])
  @@index([mergedAt])
}

