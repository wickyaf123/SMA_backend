# ============================================
# JAMES OUTBOUND AUTOMATION - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your actual values
# cp .env.example .env

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3000

# API Key for authentication (generate a secure random string)
API_KEY=your_secure_api_key_here

# ============================================
# DATABASE (Required)
# ============================================
# Supabase PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# ============================================
# REDIS (Required)
# ============================================
# Upstash Redis connection string
REDIS_URL=redis://default:xxxxx@xxxxx.upstash.io:6379

# ============================================
# APOLLO.IO - Lead Enrichment (Required)
# ============================================
APOLLO_API_KEY=your_apollo_api_key
APOLLO_WEBHOOK_URL=https://your-domain.com/webhooks/apollo

# ============================================
# INSTANTLY.AI - Email Campaigns (Required)
# ============================================
INSTANTLY_API_KEY=your_instantly_api_key
INSTANTLY_CAMPAIGN_ID=optional_default_campaign_id

# ============================================
# TWILIO - Phone Validation (Required)
# ============================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# NEVERBOUNCE - Email Validation (Required)
# ============================================
NEVERBOUNCE_API_KEY=your_neverbounce_api_key

# ============================================
# PHANTOMBUSTER - LinkedIn Automation (Required)
# ============================================
PHANTOMBUSTER_API_KEY=your_phantombuster_api_key
PHANTOMBUSTER_PROFILE_VISITOR_AGENT_ID=optional_agent_id
PHANTOMBUSTER_CONNECTION_AGENT_ID=optional_agent_id
PHANTOMBUSTER_MESSAGE_AGENT_ID=optional_agent_id
PHANTOMBUSTER_INBOX_AGENT_ID=optional_agent_id

# ============================================
# GOOGLE SHEETS - LinkedIn Data Export (Optional)
# ============================================
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"

# ============================================
# HUNTER.IO - Email Enrichment (Phase 3.5)
# ============================================
HUNTER_API_KEY=your_hunter_api_key

# ============================================
# APIFY - Google Maps Scraping (Phase 3.5)
# ============================================
APIFY_API_KEY=your_apify_api_key

# ============================================
# GOHIGHLEVEL - SMS + CRM (Phase 3.5)
# ============================================
GHL_API_KEY=your_ghl_api_key
GHL_LOCATION_ID=your_location_id
GHL_PHONE_NUMBER=+1234567890
GHL_BASE_URL=https://services.leadconnectorhq.com

# ============================================
# EMAIL NOTIFICATIONS (Phase 3.5)
# ============================================
NOTIFICATION_EMAIL=team@yourcompany.com

# ============================================
# RATE LIMITS (Optional - defaults shown)
# ============================================
EMAIL_RATE_LIMIT_PER_HOUR=100
SMS_RATE_LIMIT_PER_HOUR=50
LINKEDIN_RATE_LIMIT_PER_DAY=50

# ============================================
# BUSINESS HOURS (Optional - defaults shown)
# ============================================
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=17
